{
  "name": "hakuneko-dev",
  "version": "1.0.0",
  "description": "HakuNeko",
  "author": "The HakuNeko Development Team <https://github.com/orgs/manga-download/people>",
  "license": "Unlicense",
  "main": "src/app/main.js",
  "repository": {
    "type": "git",
    "url": "https://git.io/hakuneko"
  },
  "devDependencies": {
    "@electron/asar": "^4.2.0",
    "@hakuneko/ffmpeg-binaries": "4.2.1-1",
    "@hakuneko/imagemagick-binaries": "7.0.8-58-3",
    "@hakuneko/kindlegen-binaries": "2.9.0-3",
    "@logtrine/logtrine": "1.1.2",
    "@typescript-eslint/eslint-plugin": "^7",
    "@typescript-eslint/parser": "^7",
    "assjs": "^0.1.6",
    "crypto-js": "^4.2.0",
    "discord-rpc": "4.0.1",
    "electron": "33.4.11",
    "eslint": "^8.57.0",
    "exif-js": "^2.3.0",
    "fs-extra": "11.3.4",
    "hls.js": "^1.6.16",
    "innosetup-compiler": "6.3.1",
    "jest": "30.3.0",
    "jest-circus": "30.3.0",
    "jest-junit": "16.0.0",
    "jszip": "3.10.1",
    "oauth-1.0a": "^2.2.6",
    "pdfkit": "^0.18.0",
    "protobufjs": "^8.0.1",
    "rcedit": "5.0.2",
    "sql.js": "^1.14.1",
    "typescript": "^6.0.3",
    "vite": "^6.0.0",
    "vite-plugin-static-copy": "^2.0.0",
    "win-7zip": "0.1.1"
  },
  "scripts": {
    "postinstall": "cd src/app && npm install --no-optional",
    "start": "npm run start:dev",
    "start:dev": "npm run build:web && electron . --update-url=DISABLED --cache-directory=./build/web --disable-http-cache --disable-gpu-vsync",
    "start:build": "npm run build:web && electron . --update-url=DISABLED --cache-directory=./build/web",
    "lint": "npm run lint:app && npm run lint:web",
    "lint:app": "eslint ./src/app --ignore-path .gitignore",
    "lint:web": "eslint ./src/web/mjs/**/*.mjs --ignore-path .gitignore --parser-options ecmaVersion:2020",
    "format": "npm run format:app && npm run format:web",
    "format:app": "npm run lint:app -- --fix",
    "format:web": "npm run lint:web -- --fix",
    "build:app": "node build-app.js",
    "build:web": "vite build --config vite.config.js",
    "deploy:web": "npm run build:web && node deploy-web.js",
    "test": "jest --color --reporters=default --reporters=jest-junit",
    "test:app": "jest --color --reporters=default --reporters=jest-junit --testPathPattern=/src/app",
    "test:web": "jest --color --reporters=default --reporters=jest-junit --testPathPattern=/src/web",
    "test:e2e": "jest --color --reporters=default --reporters=jest-junit --testPathPattern=/src/__tests__",
    "test:smoke:tier1": "cd tools/smoke-test && bun run tier1",
    "test:smoke:tier2": "cd tools/smoke-test && bun run tier2",
    "test:smoke:tier3": "cd tools/smoke-test && bun run tier3",
    "scan:dead-links": "cd tools/connector-gen && bun run scan",
    "typecheck": "tsc --noEmit"
  },
  "jest": {
    "testPathIgnorePatterns": [
      "/node_modules/",
      "<rootDir>/tools/"
    ]
  },
  "dependencies": {
    "puppeteer-core": "3.3.0"
  }
}
