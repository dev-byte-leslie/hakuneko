{
    "compilerOptions": {
        "allowJs": true,
        "strict": true,
        "noEmit": true,
        "moduleResolution": "bundler",
        "module": "ESNext",
        "target": "ESNext",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "experimentalDecorators": true,
        "useDefineForClassFields": false
    },
    "include": [
        "src/web/mjs/engine/**/*.ts",
        "src/web/mjs/engine/**/*.d.ts",
        "src/web/lib/hakuneko/frontend@classic/*.ts"
    ],
    "exclude": ["node_modules", "build"]
}
